generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Person {
  id           Int        @id @default(autoincrement())
  name         String
  role         String     @default("USER") // USER, MANAGER (Mother), ADMIN
  ha_entity_id String?
  contact_id   String?
  guest_token  String?    @unique
  login_token  String?    @unique
  pin_code     String?    @default("1234")
  acl          String?    @db.LongText
  bedtime      String?
  schedules    Schedule[]
  tasks        Task[]
  accounts     FinancialAccount[]
  memories     YasminMemory[]
}

model FinancialAccount {
  id            Int           @id @default(autoincrement())
  person_id     Int
  name          String
  iban_hash     String?       @db.VarChar(255)
  balance       Decimal       @default(0.00) @db.Decimal(10, 2)
  currency      String        @default("EUR")
  type          String        @default("CHECKING") // CHECKING, SAVINGS
  person        Person        @relation(fields: [person_id], references: [id])
  pots          FinancialPot[]
  transactions  FinancialTransaction[]

  @@index([person_id])
}

model FinancialPot {
  id              Int           @id @default(autoincrement())
  account_id      Int
  name            String
  target_amount   Decimal?      @db.Decimal(10, 2)
  current_balance Decimal       @default(0.00) @db.Decimal(10, 2)
  category        String        // RENT, GROCERIES, UTILITIES, SAVINGS, etc.
  is_locked       Boolean       @default(false)
  account         FinancialAccount @relation(fields: [account_id], references: [id])
  transactions    FinancialTransaction[]
  rules           FinancialRule[]

  @@index([account_id])
}

model FinancialTransaction {
  id          Int               @id @default(autoincrement())
  account_id  Int
  pot_id      Int?
  amount      Decimal           @db.Decimal(10, 2)
  description String?           @db.Text
  timestamp   DateTime          @default(now())
  direction   String            @default("OUT") // IN, OUT
  account     FinancialAccount  @relation(fields: [account_id], references: [id])
  pot         FinancialPot?     @relation(fields: [pot_id], references: [id])

  @@index([account_id])
  @@index([pot_id])
}

model YasminMemory {
  id               Int      @id @default(autoincrement())
  person_id        Int
  subject          String   @db.VarChar(255)
  fact_content     String   @db.Text
  category         String?  @db.VarChar(100)
  importance_score Int      @default(3) // 1-5
  created_at       DateTime @default(now())
  last_accessed    DateTime @updatedAt
  person           Person   @relation(fields: [person_id], references: [id])

  @@index([person_id])
}

model SecureVault {
  id              Int      @id @default(autoincrement())
  key_name        String   @unique @db.VarChar(255)
  encrypted_value String   @db.LongText
  iv              String   @db.VarChar(255)
  auth_tag        String   @db.VarChar(255)
  access_level    String   @default("USER") // USER, MANAGER, ADMIN
  updated_at      DateTime @updatedAt
}

model ConversationArchive {
  id              Int      @id @default(autoincrement())
  title           String?  @db.VarChar(255)
  transcript      String   @db.LongText
  summary         String?  @db.Text
  mood            String?  @db.VarChar(50)
  detected_tasks  String?  @db.LongText // JSON array of extracted tasks
  created_at      DateTime @default(now())
  audio_path      String?  @db.VarChar(500)
}

model Schedule {
  id          Int    @id @default(autoincrement())
  person_id   Int
  day_of_week Int
  start_time  String
  end_time    String
  person      Person @relation(fields: [person_id], references: [id])

  @@index([person_id], map: "Schedule_person_id_fkey")
}

model Task {
  id                 Int       @id @default(autoincrement())
  title              String
  description        String?   @db.Text
  column             String
  assigned_to_id     Int?
  energy_tag         String?
  prep_tasks         String?   @db.LongText
  travel_time_alert  Boolean   @default(false)
  metadata           String?   @db.LongText
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deadline           DateTime?
  is_flexible        Boolean   @default(true)
  deletedAt          DateTime?
  deletionReason     String?   @db.Text
  estimated_duration Int?
  depends_on_id      Int?
  assigned_to        Person?   @relation(fields: [assigned_to_id], references: [id])
  parent_task        Task?     @relation("TaskDependencies", fields: [depends_on_id], references: [id])
  dependent_tasks    Task[]    @relation("TaskDependencies")

  @@index([assigned_to_id], map: "Task_assigned_to_id_fkey")
  @@index([depends_on_id], map: "Task_depends_on_id_fkey")
}

model UserContext {
  id             Int      @id @default(autoincrement())
  key            String   @unique
  is_son_present Boolean  @default(false)
  current_energy Int      @default(5)
  last_updated   DateTime @default(now()) @updatedAt
}

model RawCalendarEvent {
  id            String    @db.VarChar(255)
  calendar_name String?   @db.VarChar(100)
  summary       String?   @db.MediumText
  start_time    DateTime  @db.DateTime(0)
  end_time      DateTime? @db.DateTime(0)
  is_recurring  Boolean?  @default(false)
  fetched_at    DateTime? @default(now()) @db.Timestamp(0)
  full_json     String?   @db.LongText

  @@id([id, start_time])
  @@map("raw_calendar_events")
}

model ReconciliationProposal {
  id                   Int                                       @id @default(autoincrement())
  event_id             String?                                   @db.VarChar(255)
  original_calendar_id String?                                   @db.VarChar(255)
  original_summary     String?                                   @db.MediumText
  original_start       DateTime?                                 @db.DateTime(0)
  original_end         DateTime?                                 @db.DateTime(0)
  proposed_action      reconciliation_proposals_proposed_action?
  proposed_start       DateTime?                                 @db.DateTime(0)
  proposed_end         DateTime?                                 @db.DateTime(0)
  reason               String?                                   @db.MediumText
  change_description   String?                                   @db.MediumText
  status               reconciliation_proposals_status?          @default(PENDING)
  created_at           DateTime?                                 @default(now()) @db.Timestamp(0)

  @@map("reconciliation_proposals")
}

model Chat {
  id         String    @id
  remoteJid  String    @db.VarChar(100)
  labels     String?   @db.LongText
  createdAt  DateTime? @default(now()) @db.Timestamp(0)
  updatedAt  DateTime? @db.Timestamp(0)
  instanceId String
}

model Chatwoot {
  id                      String    @id
  enabled                 Boolean?  @default(true)
  accountId               String?   @db.VarChar(100)
  token                   String?   @db.VarChar(100)
  url                     String?   @db.VarChar(500)
  nameInbox               String?   @db.VarChar(100)
  signMsg                 Boolean?  @default(false)
  signDelimiter           String?   @db.VarChar(100)
  number                  String?   @db.VarChar(100)
  reopenConversation      Boolean?  @default(false)
  conversationPending     Boolean?  @default(false)
  mergeBrazilContacts     Boolean?  @default(false)
  importContacts          Boolean?  @default(false)
  importMessages          Boolean?  @default(false)
  daysLimitImportMessages Int?
  organization            String?   @db.VarChar(100)
  logo                    String?   @db.VarChar(500)
  createdAt               DateTime? @default(now()) @db.Timestamp(0)
  updatedAt               DateTime  @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  instanceId              String    @unique
}

model Contact {
  id            String    @id
  remoteJid     String    @db.VarChar(100)
  pushName      String?   @db.VarChar(100)
  profilePicUrl String?   @db.VarChar(500)
  createdAt     DateTime? @default(now()) @db.Timestamp(0)
  updatedAt     DateTime? @db.Timestamp(0)
  instanceId    String
}

model Instance {
  id                      String                    @id
  name                    String                    @unique @db.VarChar(255)
  connectionStatus        Instance_connectionStatus @default(open)
  ownerJid                String?                   @db.VarChar(100)
  profileName             String?                   @db.VarChar(100)
  profilePicUrl           String?                   @db.VarChar(500)
  integration             String?                   @db.VarChar(100)
  number                  String?                   @db.VarChar(100)
  businessId              String?                   @db.VarChar(100)
  token                   String?                   @db.VarChar(255)
  clientName              String?                   @db.VarChar(100)
  disconnectionReasonCode Int?
  disconnectionObject     String?                   @db.LongText
  disconnectionAt         DateTime?                 @db.Timestamp(0)
  createdAt               DateTime?                 @default(now()) @db.Timestamp(0)
  updatedAt               DateTime?                 @db.Timestamp(0)
  OpenaiBot               OpenaiBot[]
  OpenaiCreds             OpenaiCreds[]
  OpenaiSession           OpenaiSession[]
  OpenaiSetting           OpenaiSetting?
  Proxy                   Proxy?
  Rabbitmq                Rabbitmq?
  Setting                 Setting?
  Sqs                     Sqs?
  Template                Template[]
  Typebot                 Typebot[]
  TypebotSession          TypebotSession[]
  TypebotSetting          TypebotSetting?
  Websocket               Websocket?
}

model Label {
  id           String    @id
  labelId      String?   @unique @db.VarChar(100)
  name         String    @db.VarChar(100)
  color        String    @db.VarChar(100)
  predefinedId String?   @db.VarChar(100)
  createdAt    DateTime? @default(now()) @db.Timestamp(0)
  updatedAt    DateTime  @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  instanceId   String
}

model Message {
  id                           String         @id
  key                          String         @db.LongText
  pushName                     String?        @db.VarChar(100)
  participant                  String?        @db.VarChar(100)
  messageType                  String         @db.VarChar(100)
  message                      String         @db.LongText
  contextInfo                  String?        @db.LongText
  source                       Message_source
  messageTimestamp             Int
  chatwootMessageId            Int?
  chatwootInboxId              Int?
  chatwootConversationId       Int?
  chatwootContactInboxSourceId String?        @db.VarChar(100)
  chatwootIsRead               Boolean?       @default(false)
  instanceId                   String
  typebotSessionId             String?
  openaiSessionId              String?
  webhookUrl                   String?        @db.VarChar(500)
  difySessionId                String?
}

model MessageUpdate {
  id          String  @id
  keyId       String  @db.VarChar(100)
  remoteJid   String  @db.VarChar(100)
  fromMe      Boolean
  participant String? @db.VarChar(100)
  pollUpdates String? @db.LongText
  status      String  @db.VarChar(30)
  messageId   String
  instanceId  String
}

model OpenaiBot {
  id                String                     @id
  enabled           Boolean                    @default(true)
  description       String?                    @db.VarChar(255)
  botType           OpenaiBot_botType
  assistantId       String?                    @db.VarChar(255)
  functionUrl       String?                    @db.VarChar(500)
  model             String?                    @db.VarChar(100)
  systemMessages    String?                    @db.LongText
  assistantMessages String?                    @db.LongText
  userMessages      String?                    @db.LongText
  maxTokens         Int?
  expire            Int?                       @default(0)
  keywordFinish     String?                    @db.VarChar(100)
  delayMessage      Int?
  unknownMessage    String?                    @db.VarChar(100)
  listeningFromMe   Boolean?                   @default(false)
  stopBotFromMe     Boolean?                   @default(false)
  keepOpen          Boolean?                   @default(false)
  debounceTime      Int?
  ignoreJids        String?                    @db.LongText
  triggerType       OpenaiBot_triggerType?
  triggerOperator   OpenaiBot_triggerOperator?
  triggerValue      String?
  createdAt         DateTime?                  @default(now()) @db.Timestamp(0)
  updatedAt         DateTime                   @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  openaiCredsId     String
  instanceId        String
  Instance          Instance                   @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  OpenaiCreds       OpenaiCreds                @relation(fields: [openaiCredsId], references: [id], onDelete: Cascade)
  OpenaiSession     OpenaiSession[]
  OpenaiSetting     OpenaiSetting[]

  @@index([instanceId], map: "OpenaiBot_instanceId_fkey")
  @@index([openaiCredsId], map: "OpenaiBot_openaiCredsId_fkey")
}

model OpenaiCreds {
  id            String         @id
  name          String?        @unique @db.VarChar(255)
  apiKey        String?        @unique @db.VarChar(255)
  createdAt     DateTime?      @default(now()) @db.Timestamp(0)
  updatedAt     DateTime       @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  instanceId    String
  OpenaiBot     OpenaiBot[]
  Instance      Instance       @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  OpenaiSetting OpenaiSetting?

  @@index([instanceId], map: "OpenaiCreds_instanceId_fkey")
}

model OpenaiSession {
  id          String               @id
  sessionId   String               @db.VarChar(255)
  remoteJid   String               @db.VarChar(100)
  status      OpenaiSession_status
  awaitUser   Boolean              @default(false)
  createdAt   DateTime?            @default(now()) @db.Timestamp(0)
  updatedAt   DateTime             @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  openaiBotId String
  instanceId  String
  Instance    Instance             @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  OpenaiBot   OpenaiBot            @relation(fields: [openaiBotId], references: [id], onDelete: Cascade)

  @@index([instanceId], map: "OpenaiSession_instanceId_fkey")
  @@index([openaiBotId], map: "OpenaiSession_openaiBotId_fkey")
}

model OpenaiSetting {
  id               String      @id
  expire           Int?        @default(0)
  keywordFinish    String?     @db.VarChar(100)
  delayMessage     Int?
  unknownMessage   String?     @db.VarChar(100)
  listeningFromMe  Boolean?    @default(false)
  stopBotFromMe    Boolean?    @default(false)
  keepOpen         Boolean?    @default(false)
  debounceTime     Int?
  ignoreJids       String?     @db.LongText
  speechToText     Boolean?    @default(false)
  createdAt        DateTime?   @default(now()) @db.Timestamp(0)
  updatedAt        DateTime    @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  openaiCredsId    String      @unique
  openaiIdFallback String?     @db.VarChar(100)
  instanceId       String      @unique
  Instance         Instance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  OpenaiCreds      OpenaiCreds @relation(fields: [openaiCredsId], references: [id])
  OpenaiBot        OpenaiBot?  @relation(fields: [openaiIdFallback], references: [id])

  @@index([openaiIdFallback], map: "OpenaiSetting_openaiIdFallback_fkey")
}

model Proxy {
  id         String    @id
  enabled    Boolean   @default(false)
  host       String    @db.VarChar(100)
  port       String    @db.VarChar(100)
  protocol   String    @db.VarChar(100)
  username   String    @db.VarChar(100)
  password   String    @db.VarChar(100)
  createdAt  DateTime? @default(now()) @db.Timestamp(0)
  updatedAt  DateTime  @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  instanceId String    @unique
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Rabbitmq {
  id         String    @id
  enabled    Boolean   @default(false)
  events     String    @db.LongText
  createdAt  DateTime? @default(now()) @db.Timestamp(0)
  updatedAt  DateTime  @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  instanceId String    @unique
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id
  sessionId String   @unique
  creds     String?  @db.Text
  createdAt DateTime @default(now()) @db.Timestamp(0)
}

model Setting {
  id              String    @id
  rejectCall      Boolean   @default(false)
  msgCall         String?   @db.VarChar(100)
  groupsIgnore    Boolean   @default(false)
  alwaysOnline    Boolean   @default(false)
  readMessages    Boolean   @default(false)
  readStatus      Boolean   @default(false)
  syncFullHistory Boolean   @default(false)
  createdAt       DateTime? @default(now()) @db.Timestamp(0)
  updatedAt       DateTime  @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  instanceId      String    @unique
  Instance        Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Sqs {
  id         String    @id
  enabled    Boolean   @default(false)
  events     String    @db.LongText
  createdAt  DateTime? @default(now()) @db.Timestamp(0)
  updatedAt  DateTime  @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  instanceId String    @unique
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Template {
  id         String    @id
  templateId String    @unique @db.VarChar(255)
  name       String    @unique @db.VarChar(255)
  template   String    @db.LongText
  webhookUrl String?   @db.VarChar(500)
  createdAt  DateTime? @default(now()) @db.Timestamp(0)
  updatedAt  DateTime  @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  instanceId String
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId], map: "Template_instanceId_fkey")
}

model Typebot {
  id              String                   @id
  enabled         Boolean                  @default(true)
  description     String?                  @db.VarChar(255)
  url             String                   @db.VarChar(500)
  typebot         String                   @db.VarChar(100)
  expire          Int?                     @default(0)
  keywordFinish   String?                  @db.VarChar(100)
  delayMessage    Int?
  unknownMessage  String?                  @db.VarChar(100)
  listeningFromMe Boolean?                 @default(false)
  stopBotFromMe   Boolean?                 @default(false)
  keepOpen        Boolean?                 @default(false)
  debounceTime    Int?
  createdAt       DateTime?                @default(now()) @db.Timestamp(0)
  updatedAt       DateTime?                @db.Timestamp(0)
  ignoreJids      String?                  @db.LongText
  triggerType     Typebot_triggerType?
  triggerOperator Typebot_triggerOperator?
  triggerValue    String?
  instanceId      String
  Instance        Instance                 @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  TypebotSession  TypebotSession[]
  TypebotSetting  TypebotSetting[]

  @@index([instanceId], map: "Typebot_instanceId_fkey")
}

model TypebotSession {
  id                 String                @id
  remoteJid          String                @db.VarChar(100)
  pushName           String?               @db.VarChar(100)
  sessionId          String                @db.VarChar(100)
  status             TypebotSession_status
  prefilledVariables String?               @db.LongText
  awaitUser          Boolean               @default(false)
  createdAt          DateTime?             @default(now()) @db.Timestamp(0)
  updatedAt          DateTime              @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  typebotId          String
  instanceId         String
  Instance           Instance              @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  Typebot            Typebot               @relation(fields: [typebotId], references: [id], onDelete: Cascade)

  @@index([instanceId], map: "TypebotSession_instanceId_fkey")
  @@index([typebotId], map: "TypebotSession_typebotId_fkey")
}

model TypebotSetting {
  id                String    @id
  expire            Int?      @default(0)
  keywordFinish     String?   @db.VarChar(100)
  delayMessage      Int?
  unknownMessage    String?   @db.VarChar(100)
  listeningFromMe   Boolean?  @default(false)
  stopBotFromMe     Boolean?  @default(false)
  keepOpen          Boolean?  @default(false)
  debounceTime      Int?
  typebotIdFallback String?   @db.VarChar(100)
  ignoreJids        String?   @db.LongText
  createdAt         DateTime? @default(now()) @db.Timestamp(0)
  updatedAt         DateTime  @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  instanceId        String    @unique
  Instance          Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  Typebot           Typebot?  @relation(fields: [typebotIdFallback], references: [id])

  @@index([typebotIdFallback], map: "TypebotSetting_typebotIdFallback_fkey")
}

model Webhook {
  id              String    @id
  url             String    @db.VarChar(500)
  enabled         Boolean?  @default(true)
  events          String?   @db.LongText
  webhookByEvents Boolean?  @default(false)
  webhookBase64   Boolean?  @default(false)
  createdAt       DateTime? @default(now()) @db.Timestamp(0)
  updatedAt       DateTime  @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  instanceId      String    @unique
}

model Websocket {
  id         String    @id
  enabled    Boolean   @default(false)
  events     String    @db.LongText
  createdAt  DateTime? @default(now()) @db.Timestamp(0)
  updatedAt  DateTime  @default(dbgenerated("'0000-00-00 00:00:00'")) @db.Timestamp(0)
  instanceId String    @unique
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model blacklist {
  id           Int      @id @default(autoincrement())
  phone_number String   @unique(map: "phone_number") @db.VarChar(20)
  reason       String?  @db.Text
  created_at   DateTime @default(now()) @db.Timestamp(0)
}

model correction_logs {
  id                          Int       @id @default(autoincrement())
  message                     String?   @db.Text
  local_orchestrator_response String?   @db.LongText
  gemini_response             String?   @db.LongText
  agreement                   Boolean?
  user_correction             String?   @db.Text
  created_at                  DateTime? @default(now()) @db.Timestamp(0)
}

model google_tokens {
  id            Int       @id @default(autoincrement())
  user_email    String?   @unique(map: "user_email") @db.VarChar(255)
  access_token  String?   @db.Text
  refresh_token String?   @db.Text
  expiry_date   BigInt?
  created_at    DateTime? @default(now()) @db.Timestamp(0)
}

model NotificationQueue {
  id        Int      @id @default(autoincrement())
  source    String
  content   String   @db.Text
  status    String   @default("'pending'")
  createdAt DateTime @default(now()) @db.Timestamp(0)

  @@map("notification_queue")
}

model RecurringTask {
  id                 Int             @id @default(autoincrement())
  title              String
  description        String?
  frequency          String
  assignee_id        Int?
  energy_cost        String
  estimated_duration Int
  next_run_at        DateTime
  last_run_at        DateTime?
  is_active          Boolean         @default(true)
  depends_on_id      Int?
  starting_date      DateTime        @default(now())
  parent_task        RecurringTask?  @relation("RecurringTaskDependencies", fields: [depends_on_id], references: [id])
  dependent_tasks    RecurringTask[] @relation("RecurringTaskDependencies")

  @@index([depends_on_id], map: "RecurringTask_depends_on_id_fkey")
}

model SchoolEventMap {
  id        Int      @id @default(autoincrement())
  title     String   @unique
  category  String
  ai_reason String?  @db.Text
  updatedAt DateTime @default(now()) @updatedAt

  @@map("school_event_map")
}

model Voice_Session {
  id              String               @id @default(uuid())
  start_time      DateTime             @default(now())
  end_time        DateTime?
  full_transcript String               @db.Text
  inferred_mood   String
  energy_level    Int
  raw_audio_path  String?
  ideas           Idea_Session_Pivot[]
}

model Idea {
  id         String               @id @default(uuid())
  name       String
  base_idea  String               @db.Text
  markdown   String               @db.Text
  status     String
  created_at DateTime             @default(now())
  updated_at DateTime             @updatedAt
  sessions   Idea_Session_Pivot[]
}

model Idea_Session_Pivot {
  idea_id    String
  session_id String
  idea       Idea          @relation(fields: [idea_id], references: [id], onDelete: Cascade)
  session    Voice_Session @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@id([idea_id, session_id])
  @@index([session_id], map: "Idea_Session_Pivot_session_id_fkey")
}

model KnowledgeEntry {
  id         String   @id @default(uuid())
  topic      String
  content    String   @db.Text
  source     String?
  verified   Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("knowledge_entries")
}

model ContactBackup {
  id          Int      @id @default(autoincrement())
  snapshot    String   @db.LongText
  created_at  DateTime @default(now())

  @@map("contact_backups")
}

enum Instance_connectionStatus {
  open
  close
  connecting
